---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import PageHero from "@components/PageHero.astro";
import ArticleCard from "@components/ArticleCard.astro";
import { breadcrumbJsonLd } from "@/lib/seo";

const pubs = (await getCollection("publications")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const [latest, ...rest] = pubs;
const seriesCount = new Set(pubs.map((p) => p.data.series).filter(Boolean))
  .size;
---

<Base
  title="Publications"
  description="Technical writing by AmirHossein Aghajari — deep dives on performance, systems, concurrency, and the Android stack. Previews here; full articles on Medium."
  jsonLd={[
    breadcrumbJsonLd([
      { name: "Home", path: "/" },
      { name: "Publications", path: "/publications" },
    ]),
  ]}
>
  <PageHero
    eyebrow="Writing · Medium"
    title="Writing about the internals"
    intro="I write to understand. These are previews of every article — performance, systems, concurrency, and graphics when the topic goes there — each linking to the full piece on Medium."
  >
    <div class="pub-stats" data-reveal style="--reveal-delay:180ms">
      <span class="mono">{pubs.length} articles</span>
      <span class="dot-sep">·</span>
      <span class="mono">{seriesCount} series</span>
      <span class="dot-sep">·</span>
      <span class="mono">previews + full reads on Medium</span>
    </div>
  </PageHero>

  <section class="section">
    <div class="container">
      {
        latest && (
          <div class="latest">
            <ArticleCard entry={latest} feature animatedCover={false} />
          </div>
        )
      }
      <div class="grid grid-3">
        {rest.map((p) => <ArticleCard entry={p} />)}
      </div>
    </div>
  </section>
</Base>

<style>
  .pub-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6em;
    align-items: center;
    margin-top: var(--space-6);
    color: var(--text-3);
    font-size: 0.85rem;
  }
  .dot-sep {
    opacity: 0.5;
  }
  .latest {
    margin-bottom: var(--space-6);
  }
</style>
