---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ArticleCard from "@components/ArticleCard.astro";
import TalkCard from "@components/TalkCard.astro";
import Icon from "@components/Icon.astro";
import { profile, stats } from "@data/profile";
import { personJsonLd, websiteJsonLd } from "@/lib/seo";

const pubs = (await getCollection("publications")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featuredPubs = pubs.filter((p) => p.data.featured).slice(0, 3);

const talks = (await getCollection("presentations")).sort((a, b) => {
  const da = a.data.date?.valueOf() ?? 0;
  const db = b.data.date?.valueOf() ?? 0;
  return db - da;
});
const featuredTalks = talks.filter((t) => t.data.featured);
---

<Base description={profile.description} jsonLd={[personJsonLd(), websiteJsonLd()]}>
  <!-- ===================== HERO ===================== -->
  <section class="hero grid-bg">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-inner">
      <p class="eyebrow hero-eyebrow" data-reveal>
        {profile.role} · {profile.company}
      </p>
      <h1 class="display hero-title" data-reveal style="--reveal-delay:60ms">
        Engineering the<br />
        way things <span class="text-gradient hero-move">move.</span>
      </h1>
      <p class="lead hero-statement" data-reveal style="--reveal-delay:140ms">
        I'm {profile.name} — an Android engineer. I build systems,
        motion and graphics, and I write about how they work underneath.
      </p>

      <div class="hero-actions" data-reveal style="--reveal-delay:220ms">
        <a href="/presentations" class="btn btn--accent">
          Explore the talks <Icon name="arrow" size={18} class="arrow" />
        </a>
        <a href="/publications" class="btn btn--ghost">
          <Icon name="pen" size={17} /> Read the writing
        </a>
      </div>

      <ul class="hero-facets" data-reveal style="--reveal-delay:300ms" aria-label="Focus areas">
        {profile.facets.map((f) => <li class="tag">{f}</li>)}
      </ul>
    </div>

    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-track"><span class="scroll-thumb"></span></span>
    </div>
  </section>

  <!-- ===================== STATS ===================== -->
  <section class="section-tight stats-section">
    <div class="container">
      <ul class="stats-grid">
        {stats.map((s) => (
          <li class="stat" data-reveal>
            <span class="stat-value">{s.value}<span class="stat-suffix">{s.suffix}</span></span>
            <span class="stat-label">{s.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===================== TALKS (first — what matters most) ===================== -->
  <section class="section home-talks">
    <div class="container">
      <SectionHeading
        eyebrow="Speaking"
        title="Talks, rebuilt for the web"
        intro="The work I care about most — conference talks turned into interactive pages you can explore at your own pace."
        link={{ href: "/presentations", label: "All presentations" }}
      />
      <div class="grid grid-3">
        {featuredTalks.map((t) => <TalkCard entry={t} />)}
      </div>
    </div>
  </section>

  <!-- ===================== WRITING ===================== -->
  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Writing"
        title="Explaining what happens underneath"
        intro="Deep dives on graphics, animation and performance — previewed here, read in full on Medium."
        link={{ href: "/publications", label: "All publications" }}
      />
      <div class="pub-feature">
        {featuredPubs[0] && <ArticleCard entry={featuredPubs[0]} feature />}
      </div>
      <div class="grid grid-2 pub-rest">
        {featuredPubs.slice(1).map((p) => <ArticleCard entry={p} />)}
      </div>
    </div>
  </section>

  <!-- ===================== CLOSING ===================== -->
  <section class="section">
    <div class="container">
      <div class="home-cta" data-reveal>
        <p class="eyebrow">Say hello</p>
        <h2 class="home-cta__title">
          Happy to talk <span class="text-gradient">engineering.</span>
        </h2>
        <p class="home-cta__text muted">
          No agenda needed — reach out on whichever channel feels easiest.
        </p>
        <div class="home-cta__actions">
          <a href="/contact" class="btn btn--accent">
            Get in touch <Icon name="arrow" size={18} class="arrow" />
          </a>
          <a href={profile.socials.linkedin} target="_blank" rel="noopener" class="btn btn--ghost">
            <Icon name="linkedin" size={17} /> LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    min-height: min(92vh, 880px);
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: var(--space-9) var(--space-8);
  }
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, var(--bg));
    pointer-events: none;
  }
  .hero-glow {
    position: absolute;
    top: -22%;
    left: 50%;
    width: min(900px, 90vw);
    aspect-ratio: 1.6;
    transform: translateX(-50%);
    background: radial-gradient(closest-side, var(--glow), transparent 70%);
    filter: blur(20px);
    opacity: 0.85;
    pointer-events: none;
    animation: float-soft 12s var(--ease-in-out) infinite;
  }
  :global([data-theme="light"]) .hero-glow {
    opacity: 1;
    filter: blur(28px);
  }
  .hero-inner { position: relative; z-index: 1; max-width: 980px; }
  .hero-eyebrow { margin-bottom: var(--space-5); }
  .hero-title { font-size: clamp(2.8rem, 1.6rem + 6vw, 6.4rem); }
  .hero-move {
    background-size: 220% 220%;
    animation: aurora-pan 8s var(--ease-in-out) infinite;
  }
  .hero-statement { margin-top: var(--space-5); max-width: 62ch; line-height: 1.65; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-6); }
  .hero-facets { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-7); }

  .scroll-hint {
    position: absolute;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
  }
  .scroll-track {
    display: block; width: 22px; height: 36px;
    border: 1.5px solid var(--border-strong); border-radius: var(--radius-pill);
    position: relative;
  }
  .scroll-thumb {
    position: absolute; top: 7px; left: 50%; transform: translateX(-50%);
    width: 3px; height: 7px; border-radius: 2px; background: var(--text-2);
    animation: scroll-bob 1.8s var(--ease-in-out) infinite;
  }
  @keyframes scroll-bob { 0%,100% { transform: translate(-50%, 0); opacity: 1; } 50% { transform: translate(-50%, 10px); opacity: 0.3; } }

  /* ---------- Stats ---------- */
  .stats-section { border-block: 1px solid var(--border); }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
    list-style: none;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .stat-value {
    font-size: var(--step-4);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-suffix { color: var(--accent); }
  .stat-label { color: var(--text-3); font-size: 0.85rem; }
  @media (max-width: 640px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-6) var(--space-5); }
  }

  /* ---------- Talks accent ---------- */
  .home-talks {
    background:
      radial-gradient(100% 60% at 50% 0%, color-mix(in srgb, var(--accent) 5%, transparent), transparent 60%),
      var(--bg);
    border-bottom: 1px solid var(--border);
  }

  /* ---------- Writing layout ---------- */
  .pub-feature { margin-bottom: var(--space-5); }

  /* ---------- Closing CTA ---------- */
  .home-cta {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: clamp(2.5rem, 6vw, 4.5rem) var(--space-5);
    border-radius: var(--radius-xl, var(--radius-lg));
    border: 1px solid var(--border);
    background:
      radial-gradient(120% 140% at 50% 0%, color-mix(in srgb, var(--accent) 9%, transparent), transparent 60%),
      var(--surface);
  }
  .home-cta__title {
    font-size: var(--step-4);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-top: var(--space-3);
  }
  .home-cta__text { margin: var(--space-4) auto 0; max-width: 48ch; }
  .home-cta__actions {
    display: flex; flex-wrap: wrap; gap: var(--space-3);
    justify-content: center; margin-top: var(--space-6);
  }
</style>
