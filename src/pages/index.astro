---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import SectionHeading from "@components/SectionHeading.astro";
import ArticleCard from "@components/ArticleCard.astro";
import TalkCard from "@components/TalkCard.astro";
import BookCard from "@components/BookCard.astro";
import Icon from "@components/Icon.astro";
import { profile, homeJourney } from "@data/profile";
import { topRatedBooks } from "@data/reading";
import { personJsonLd, websiteJsonLd } from "@/lib/seo";

const pubs = (await getCollection("publications")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const featuredPubs = pubs.filter((p) => p.data.featured).slice(0, 3);

const talks = (await getCollection("presentations")).sort((a, b) => {
  const da = a.data.date?.valueOf() ?? 0;
  const db = b.data.date?.valueOf() ?? 0;
  return db - da;
});
const featuredTalks = talks.filter((t) => t.data.featured);
const topBooks = topRatedBooks(5);

const homeStats = [
  { value: "9", suffix: "+", label: "Years building" },
  { value: String(pubs.length), suffix: "", label: "Technical articles" },
  { value: String(talks.length), suffix: "", label: "Presentations" },
  { value: "60", suffix: "+", label: "Open-source libraries" },
];

const heroLead = profile.heroLead
  .replace("{name}", profile.name)
  .replace("{role}", profile.role)
  .replace("{company}", profile.company);
---

<Base
  description={profile.description}
  jsonLd={[personJsonLd(), websiteJsonLd()]}
>
  <section class="hero grid-bg">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-inner">
      <p class="eyebrow hero-eyebrow" data-reveal>
        {profile.role} · {profile.company}
      </p>
      <h1 class="display hero-title" data-reveal style="--reveal-delay:60ms">
        Engineering the<br />
        way things <span class="text-gradient hero-move">move.</span>
      </h1>
      <p class="lead hero-statement" data-reveal style="--reveal-delay:140ms">
        {heroLead}
      </p>

      <div class="hero-actions" data-reveal style="--reveal-delay:220ms">
        <a href="#speaking" class="btn btn--accent">
          Explore the talks <Icon name="arrow" size={18} class="arrow" />
        </a>
        <a href="#writing" class="btn btn--ghost">
          <Icon name="pen" size={17} /> Read the writing
        </a>
      </div>

      <ul
        class="hero-facets"
        data-reveal
        style="--reveal-delay:300ms"
        aria-label="Focus areas"
      >
        {profile.facets.map((f) => <li class="tag">{f}</li>)}
      </ul>
    </div>

    <a href="#stats" class="scroll-hint" aria-label="Scroll to highlights">
      <span class="scroll-track"><span class="scroll-thumb"></span></span>
    </a>
  </section>
  <section class="section-tight stats-section">
    <div id="stats" class="container stats-band home-anchor">
      <ul class="stats-grid">
        {
          homeStats.map((s) => (
            <li class="stat" data-reveal>
              <span class="stat-value">
                {s.value}
                <span class="stat-suffix">{s.suffix}</span>
              </span>
              <span class="stat-label">{s.label}</span>
            </li>
          ))
        }
      </ul>
      <a href={homeJourney.cta.href} class="stats-journey sheen" data-reveal>
        <span class="stats-journey__copy">
          <span class="stats-journey__label">{homeJourney.cta.label}</span>
          <span class="stats-journey__hint muted">{homeJourney.cta.hint}</span>
        </span>
        <Icon name="arrow" size={18} class="arrow" />
      </a>
    </div>
  </section>
  <section class="section home-talks">
    <div class="container">
      <div id="speaking" class="home-anchor">
        <SectionHeading
          eyebrow="Speaking"
          title="Talks, rebuilt for the web"
          intro="Conference talks turned into interactive pages — from concurrency and OS internals to animation and graphics."
          link={{ href: "/presentations", label: "All presentations" }}
        />
      </div>
      <div class="grid grid-3">
        {featuredTalks.map((t) => <TalkCard entry={t} />)}
      </div>
    </div>
  </section>
  <section class="section home-writing">
    <div class="container">
      <div id="writing" class="home-anchor">
        <SectionHeading
          eyebrow="Writing"
          title="Explaining what happens underneath"
          intro="Technical writing on how software actually works — from threads to the GPU."
          link={{ href: "/publications", label: "All publications" }}
        />
      </div>
      <div class="pub-feature">
        {featuredPubs[0] && (
          <ArticleCard entry={featuredPubs[0]} feature animatedCover={false} />
        )}
      </div>
      <div class="grid grid-2 pub-rest">
        {featuredPubs.slice(1).map((p) => <ArticleCard entry={p} />)}
      </div>
    </div>
  </section>
  {
    topBooks.length > 0 && (
      <section class="section home-reading">
        <div class="container">
          <div id="reading" class="home-anchor">
            <SectionHeading
              eyebrow="Reading"
              title="Five-star shelf"
              intro="My personal archive of notes and takeaways. No tracking—just the high-signal ideas that changed how I work, lead, and see the world."
              link={{ href: "/reading", label: "Browse the library" }}
            />
          </div>
          <div class="home-books">
            {topBooks.map((book) => (
              <BookCard book={book} />
            ))}
          </div>
        </div>
      </section>
    )
  }
  <section class="section home-contact">
    <div class="container">
      <div id="contact" class="home-cta home-anchor sheen" data-reveal>
        <p class="eyebrow">Say hello</p>
        <h2 class="home-cta__title">
          Happy to talk <span class="text-gradient">engineering.</span>
        </h2>
        <p class="home-cta__text muted">
          No agenda needed — reach out on whichever channel feels easiest.
        </p>
        <div class="home-cta__actions">
          <a href="/contact" class="btn btn--accent">
            Get in touch <Icon name="arrow" size={18} class="arrow" />
          </a>
          <a
            href={profile.socials.linkedin}
            target="_blank"
            rel="noopener"
            class="btn btn--ghost"
          >
            <Icon name="linkedin" size={17} /> LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<script src="../scripts/reading.ts"></script>

<style>
  .hero {
    position: relative;
    min-height: min(92vh, 880px);
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-block: var(--space-9) var(--space-8);
  }
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, var(--bg));
    pointer-events: none;
  }
  .hero-glow {
    position: absolute;
    top: -22%;
    left: 50%;
    width: min(900px, 90vw);
    aspect-ratio: 1.6;
    transform: translateX(-50%);
    background: radial-gradient(closest-side, var(--glow), transparent 70%);
    filter: blur(20px);
    opacity: 0.85;
    pointer-events: none;
    animation: float-soft 12s var(--ease-in-out) infinite;
  }
  :global([data-theme="light"]) .hero-glow {
    opacity: 1;
    filter: blur(28px);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 980px;
  }
  .hero-eyebrow {
    margin-bottom: var(--space-5);
  }
  .hero-title {
    font-size: clamp(2.8rem, 1.6rem + 6vw, 6.4rem);
  }
  .hero-move {
    background-size: 220% 220%;
    animation: aurora-pan 8s var(--ease-in-out) infinite;
  }
  .hero-statement {
    margin-top: var(--space-5);
    max-width: 62ch;
    line-height: 1.65;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
  .hero-facets {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-7);
  }

  .scroll-hint {
    position: absolute;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    color: inherit;
    text-decoration: none;
  }
  .scroll-track {
    display: block;
    width: 22px;
    height: 36px;
    border: 1.5px solid var(--border-strong);
    border-radius: var(--radius-pill);
    position: relative;
  }
  .scroll-thumb {
    position: absolute;
    top: 7px;
    left: 50%;
    transform: translateX(-50%);
    width: 3px;
    height: 7px;
    border-radius: 2px;
    background: var(--text-2);
    animation: scroll-bob 1.8s var(--ease-in-out) infinite;
  }
  @keyframes scroll-bob {
    0%,
    100% {
      transform: translate(-50%, 0);
      opacity: 1;
    }
    50% {
      transform: translate(-50%, 10px);
      opacity: 0.3;
    }
  }
  .stats-section {
    border-block: 1px solid var(--border);
  }
  .home-anchor {
    scroll-margin-top: calc(var(--header-h) + var(--space-7));
  }
  .stats-band {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(var(--space-5), 4vw, var(--space-7));
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
    list-style: none;
    width: 100%;
    justify-items: center;
    text-align: center;
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }
  .stat-value {
    font-size: var(--step-4);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-suffix {
    color: var(--accent);
  }
  .stat-label {
    color: var(--text-3);
    font-size: 0.85rem;
  }
  .stats-journey {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    box-shadow: inset 0 1px 0 var(--surface-highlight);
    transition:
      border-color var(--dur-mid) var(--ease-out),
      transform var(--dur-mid) var(--ease-out),
      box-shadow var(--dur-mid) var(--ease-out),
      filter var(--dur-fast) var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .stats-journey:hover {
      border-color: color-mix(in srgb, var(--accent) 28%, var(--border));
      box-shadow:
        inset 0 1px 0 var(--surface-highlight),
        0 10px 28px -22px color-mix(in srgb, var(--accent) 35%, transparent);
      transform: translateY(-1px);
    }
    .stats-journey:hover .arrow {
      transform: translateX(4px);
    }
  }
  .stats-journey__copy {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }
  .stats-journey__label {
    font-size: 0.92rem;
    font-weight: 500;
    white-space: nowrap;
  }
  .stats-journey__hint {
    font-size: 0.78rem;
    white-space: nowrap;
  }
  .stats-journey .arrow {
    flex-shrink: 0;
    color: var(--accent);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  @media (min-width: 901px) {
    .stats-band {
      flex-direction: row;
      justify-content: center;
      align-items: center;
    }
    .stats-grid {
      flex: 0 1 auto;
      max-width: 42rem;
    }
  }
  @media (max-width: 900px) {
    .stats-journey {
      width: 100%;
      max-width: 28rem;
      justify-content: space-between;
    }
  }
  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6) var(--space-5);
    }
    .stats-journey__label,
    .stats-journey__hint {
      white-space: normal;
    }
  }
  .home-talks {
    background:
      radial-gradient(
        100% 60% at 50% 0%,
        color-mix(in srgb, var(--accent) 5%, transparent),
        transparent 60%
      ),
      var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .pub-feature {
    margin-bottom: var(--space-5);
  }
  .home-reading {
    border-top: 1px solid var(--border);
    background:
      radial-gradient(
        90% 50% at 50% 100%,
        color-mix(in srgb, var(--accent) 4%, transparent),
        transparent 65%
      ),
      var(--bg);
  }
  .home-books {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: clamp(0.75rem, 2vw, 1.75rem);
    align-items: end;
    justify-items: center;
  }
  .home-books :global(.book-card) {
    width: 100%;
    max-width: 200px;
  }
  @media (max-width: 1080px) {
    .home-books {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
    .home-books :global(.book-card:nth-child(n + 5)) {
      display: none;
    }
  }
  @media (max-width: 860px) {
    .home-books {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .home-books :global(.book-card:nth-child(n + 4)) {
      display: none;
    }
  }
  @media (max-width: 580px) {
    .home-books {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .home-books :global(.book-card:nth-child(n + 3)) {
      display: none;
    }
  }
  .home-cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    text-align: center;
    padding: clamp(2.5rem, 6vw, 4.5rem) var(--space-5);
    border-radius: var(--radius-xl, var(--radius-lg));
    border: 1px solid var(--border);
    background:
      radial-gradient(
        120% 140% at 50% 0%,
        color-mix(in srgb, var(--accent) 9%, transparent),
        transparent 60%
      ),
      var(--surface);
    transition: border-color var(--dur-mid) var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .home-cta:hover {
      border-color: color-mix(in srgb, var(--accent) 32%, var(--border));
    }
  }
  .home-cta > * {
    position: relative;
    z-index: 1;
  }
  .home-cta__title {
    font-size: var(--step-4);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-top: var(--space-3);
  }
  .home-cta__text {
    margin: var(--space-4) auto 0;
    max-width: 48ch;
  }
  .home-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    margin-top: var(--space-6);
  }
</style>
