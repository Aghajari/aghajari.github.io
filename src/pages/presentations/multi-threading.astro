---
import Base from "@layouts/Base.astro";
import Icon from "@components/Icon.astro";
import { profile } from "@data/profile";
import { themeVars } from "@/lib/themes";
import { getEntry } from "astro:content";
import { presentationSeoProps, youtubeVideoId } from "@/lib/seo";

const entry = await getEntry("presentations", "multi-threading");
if (!entry) throw new Error("Missing presentation: multi-threading");
const seo = presentationSeoProps(entry);

const videoId = youtubeVideoId(entry.data.videoUrl!)!;
const videoUrl = entry.data.videoUrl!;
const speakers =
  entry.data.speakers.length > 0
    ? entry.data.speakers
    : ["AmirHossein Aghajari", "Ali Nasrabadi"];

const meta = [
  { icon: "mic", label: "Tehran, Iran" },
  { icon: "play", label: "1h 35m" },
  { icon: "pen", label: "Persian" },
  { icon: "spark", label: "Recorded" },
] as const;

const acts = [
  { id: "recording", n: "00", label: "Watch" },
  { id: "cpu", n: "01", label: "The CPU" },
  { id: "processes", n: "02", label: "Processes" },
  { id: "threads", n: "03", label: "Threads" },
  { id: "android", n: "04", label: "Android" },
  { id: "modern", n: "05", label: "Coroutines" },
];

// Cross-link to the on-site article the talk references.
const related = [
  { title: "How ValueAnimator Makes Android's UI Dance", id: "value-animator" },
];

/* ---- Code samples (plain strings, rendered verbatim) ---- */
const codeSum = `fun main() {
    println(sum(10, 20))
}

fun sum(a: Int, b: Int): Int {
    val c = a + b
    return c
}`;

const codeSwitch = `// linux/arch/arm64/kernel/entry.S — switching AArch64 tasks
SYM_FUNC_START(cpu_switch_to)
    mov   x10, #THREAD_CPU_CONTEXT
    add   x8, x0, x10            // x0 = previous task
    mov   x9, sp
    stp   x19, x20, [x8], #16    // save callee-saved registers
    stp   x21, x22, [x8], #16
    // …x23–x28…
    stp   x29, x9,  [x8], #16
    str   lr, [x8]

    add   x8, x1, x10            // x1 = next task
    ldp   x19, x20, [x8], #16    // restore callee-saved registers
    // …
    ldr   lr, [x8]
    mov   sp, x9
    ret                          // returns into the *next* task
SYM_FUNC_END(cpu_switch_to)`;

const codeFork = `int main() {
    printf("First\\n");
    int res = fork();

    if (res == 0) {
        printf("Child\\n");                       // res == 0  → we are the child
    } else if (res > 0) {
        printf("Parent: child PID is %d\\n", res); // res > 0   → child's PID
    } else {
        printf("Parent: fork failed\\n");
    }
}`;

const codeClone = `int clone(
    int flags,             // what to SHARE with the parent
    void *child_stack,     // the new execution context's stack
    int *ptid,
    int *ctid,
    unsigned long newtls   // Thread-Local Storage descriptor
);`;

const codeCloneFlags = `// glibc/nptl/pthread_create.c — how a thread is really born
const int clone_flags =
      CLONE_VM        // ← share the same memory space
    | CLONE_FS | CLONE_FILES | CLONE_SYSVSEM
    | CLONE_SIGHAND
    | CLONE_THREAD    // ← same PID: it's a thread, not a process
    | CLONE_SETTLS    // ← give it its own Thread-Local Storage
    | CLONE_PARENT_SETTID | CLONE_CHILD_CLEARTID;

__clone_internal(&args, &start_thread, pd);`;

const codeThread = `object : Thread() {
    override fun run() {
        var sum = 0
        for (i in 0..Int.MAX_VALUE / 2) {
            if (!isAlive) return
            sum += i
        }
        println("DONE=$sum")
    }
}.start()`;

const codeThreadLocal = `private val threadLocal = ThreadLocal<Int>()

fun main() {
    Thread {
        threadLocal.set(1)
        println("Thread 1: \${threadLocal.get()}")   // 1
    }.start()

    Thread {
        threadLocal.set(2)
        println("Thread 2: \${threadLocal.get()}")   // 2
    }.start()
}`;

const codeThreadLocalImpl = `class ThreadLocal<T> {
    fun set(value: T) {
        val map = Thread.currentThread().threadLocals
        map[this] = value          // 'this' ThreadLocal is the key
    }
    fun get(): T {
        val map = Thread.currentThread().threadLocals
        return map[this]           // each thread, its own map
    }
}`;

const codeLooperThread = `class MyLooperThread {
    private var handler: Handler? = null

    init {
        Thread {
            Looper.prepare()                       // 1 — give this thread a Looper
            handler = Handler(Looper.myLooper()!!) // 2 — a Handler to post into it
            Looper.loop()                          // 3 — block & process forever
        }.start()
    }

    fun post(task: () -> Unit) = handler?.post(task)
    fun postDelayed(delay: Long, task: () -> Unit) =
        handler?.postDelayed(task, delay)

    fun stop() {
        handler?.post { Looper.myLooper()?.quit() }
        handler = null
    }
}`;

const codeMainHandler = `val mainHandler = Handler(Looper.getMainLooper())

mainHandler.post {
    println("Hello from the Main Thread!")
}`;

const codeVirtual = `// JDK 21+ — millions of these are cheap
val virtualThread = Thread.ofVirtual().name("vt").start(runnable)

// the classic, expensive 1:1 OS thread
val platformThread = Thread.ofPlatform().name("pt").start(runnable)`;

const codeCoroutine = `// Coroutines do the same — thanks to suspend functions
lifecycleScope.launch(Dispatchers.IO) { myService() }
lifecycleScope.launch(Dispatchers.IO) { myService2() }`;

const codeSuspend = `suspend fun helloWorld(): String {
    delay(1000)
    return "Hello World!"
}`;

const codeCps = `// what the compiler actually generates (simplified)
fun helloWorld(completion: Continuation<*>): Any? {
    val cont = completion as? HelloWorldContinuation
        ?: HelloWorldContinuation(completion)

    when (cont.label) {
        0 -> {
            cont.label = 1
            val r = delay(1000, cont)            // pass the continuation
            if (r == COROUTINE_SUSPENDED)        // not ready? give up the thread
                return COROUTINE_SUSPENDED
        }
        1 -> { /* resumed here after the delay */ }
    }
    return "Hello World!"
}`;

const codeDelaySleep = `suspend fun test1() {
    println("Start")
    delay(1000)        // suspends — the thread is FREE to do other work
    println("End")
}

fun test2() {
    println("Start")
    Thread.sleep(1000) // blocks — the whole thread sits idle, wasted
    println("End")
}`;

const models = [
  {
    n: "1",
    name: "Callbacks",
    note: "Nesting begets nesting — the pyramid of doom.",
    code: `fun myService(callback: (String) -> Unit)

myService { res1 ->
    myService2 { res2 ->
        println(res1 + res2)
    }
}`,
  },
  {
    n: "2",
    name: "CompletableFuture",
    note: "Composable, but verbose and easy to leak.",
    code: `fun myService(): CompletableFuture<String>

val cf = myService()
    .thenCombine(myService2()) { a, b -> a + b }
println(cf.join())`,
  },
  {
    n: "3",
    name: "Reactive",
    note: "Powerful streams — and a steep learning curve.",
    code: `fun myService(): Mono<String>

myService()
    .flatMap { myService2() }
    .subscribe { res -> println(res) }`,
  },
  {
    n: "4",
    name: "Coroutines",
    note: "Reads like blocking code, runs asynchronously.",
    code: `suspend fun myService(): String

lifecycleScope.launch {
    println(myService() + myService2())
}`,
  },
];
---

<Base {...seo} flushFooter>
  <article class="mt" data-mt-root style={themeVars("systems")}>
    <header class="mt-hero">
      <canvas class="mt-hero__canvas" data-demo="hero" aria-hidden="true"
      ></canvas>
      <div class="mt-hero__veil" aria-hidden="true"></div>

      <div class="container mt-hero__inner">
        <a href="/presentations" class="mt-back" data-reveal>
          <Icon name="arrow-left" size={16} class="mt-back__arrow" /> All presentations
        </a>

        <p class="mt-eyebrow" data-reveal>Talk · Interactive edition</p>
        <h1 class="mt-title" data-reveal style="--reveal-delay:80ms">
          Multi-<span class="mt-title__break"></span>Threading
        </h1>
        <p class="mt-lede" data-reveal style="--reveal-delay:140ms">
          What really happens when code runs “at the same time”? We start at a
          single CPU executing one function and climb — through registers,
          context switches, <code>fork</code>, the Android Looper, all the way
          to the state machine Kotlin hides behind <em>suspend</em>. Every layer
          is something you can step through.
        </p>

        <div class="mt-meta" data-reveal style="--reveal-delay:200ms">
          {
            meta.map((m) => (
              <span class="mt-meta__chip">
                <Icon name={m.icon} size={13} /> {m.label}
              </span>
            ))
          }
        </div>

        <div class="mt-byline" data-reveal style="--reveal-delay:260ms">
          <span class="mt-byline__by">Presented by</span>
          <span class="mt-byline__names">
            {
              speakers.map((s, i) => (
                <>
                  {i > 0 && <span class="mt-byline__amp">&amp;</span>}
                  <span class="mt-byline__name">{s}</span>
                </>
              ))
            }
          </span>
        </div>

        <a
          href="#recording"
          class="mt-scroll"
          data-reveal
          style="--reveal-delay:320ms"
          aria-label="Watch the talk"
        >
          <span>Watch the talk</span>
          <span class="mt-scroll__line" aria-hidden="true"></span>
        </a>
      </div>
    </header>
    <nav class="mt-rail" aria-label="Chapters" data-mt-rail>
      <div class="container mt-rail__inner">
        <ol class="mt-rail__list">
          {
            acts.map((a) => (
              <li>
                <a
                  href={`#${a.id}`}
                  class="mt-rail__link"
                  data-rail-link={a.id}
                >
                  <span class="mt-rail__n mono">{a.n}</span>
                  <span class="mt-rail__label">{a.label}</span>
                </a>
              </li>
            ))
          }
        </ol>
      </div>
    </nav>
    <section class="mt-section mt-section--video" id="recording">
      <div class="container container-narrow">
        <p class="mt-kicker" data-reveal>The full talk</p>
        <h2 class="mt-h2" data-reveal>
          Watch the original — 1 hour, 35 minutes
        </h2>
        <p class="mt-prose" data-reveal>
          Start here if you want the complete journey in Persian — every
          diagram, every code dive, and the back-and-forth between both
          speakers. Then scroll on for the interactive companion below.
        </p>

        <div
          class="mt-video"
          data-demo="youtube"
          data-video-id={videoId}
          data-reveal
        >
          <button
            class="mt-video__play"
            data-yt-play
            type="button"
            aria-label="Play the talk on YouTube"
          >
            <img
              class="mt-video__thumb"
              src={`https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`}
              alt="Multi-Threading — conference talk thumbnail"
              loading="eager"
              width="1280"
              height="720"
            />
            <span class="mt-video__veil" aria-hidden="true"></span>
            <span class="mt-video__btn" aria-hidden="true"
              ><Icon name="play" size={26} /></span
            >
            <span class="mt-video__label">Play the recording</span>
          </button>
        </div>
        <a
          href={videoUrl}
          target="_blank"
          rel="noopener"
          class="mt-video__fallback"
        >
          Open on YouTube <Icon name="arrow-up-right" size={14} />
        </a>

        <a href="#cpu" class="mt-continue" data-reveal>
          Continue the interactive journey <Icon
            name="arrow"
            size={16}
            class="mt-continue__arrow"
          />
        </a>
      </div>
    </section>
    <section class="mt-section mt-intro">
      <div class="container container-narrow">
        <p class="mt-kicker" data-reveal>Bottom-up</p>
        <p class="mt-prose mt-prose--lead" data-reveal>
          Concurrency is taught backwards. We learn the high-level APIs first —
          threads, executors, coroutines — and the machinery underneath stays a
          black box. This talk does the opposite: it builds the whole stack from
          the bottom, so the abstractions at the top finally make sense.
        </p>
        <p class="mt-prose" data-reveal>
          By the end, a coroutine won't be magic. It'll be a compiler-generated
          state machine, scheduling itself onto a thread, which is itself a set
          of registers the kernel swaps onto a CPU. Here's the climb.
        </p>

        <div class="mt-overview" data-reveal>
          {
            [
              {
                n: "01",
                t: "The CPU",
                d: "Registers, the program counter, and executing one function.",
              },
              {
                n: "02",
                t: "Processes",
                d: "The PCB, context switching, fork and clone.",
              },
              {
                n: "03",
                t: "Threads",
                d: "Shared vs isolated memory, and Thread-Local Storage.",
              },
              {
                n: "04",
                t: "Android",
                d: "MessageQueue, Looper, Handler — and syncing to VSYNC.",
              },
              {
                n: "05",
                t: "Coroutines",
                d: "Virtual threads, suspend, and the CPS state machine.",
              },
            ].map((s) => (
              <div class="mt-overview__item">
                <span class="mt-overview__n mono">{s.n}</span>
                <h3 class="mt-overview__t">{s.t}</h3>
                <p class="mt-overview__d">{s.d}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>
    <section class="mt-section" id="cpu">
      <div class="container container-narrow">
        <div class="mt-act" data-reveal>
          <span class="mt-act__n mono">01</span>
          <div class="mt-act__body">
            <h2 class="mt-act__title">The CPU executes one thing</h2>
            <p class="mt-act__sub">
              A core runs a single stream of instructions, shuffling values
              between a handful of registers.
            </p>
          </div>
        </div>

        <p class="mt-prose" data-reveal>
          Underneath everything is a CPU with an arithmetic unit, a control
          unit, and a small set of <strong>registers</strong> — tiny, ultra-fast
          slots of memory. A few are special: the <code>PC</code> (program counter)
          points at the next instruction, the <code>SP</code> tracks the stack, and
          the <code>LR</code> remembers where to return.
        </p>
        <p class="mt-prose" data-reveal>
          That's all “running a program” is: read instruction, update registers,
          advance the <code>PC</code>. Step through <code>sum(10, 20)</code> and
          watch the registers change one instruction at a time.
        </p>
      </div>

      <!-- Register trace demo (built by JS) -->
      <div class="container">
        <figure class="mt-demo mt-demo--regs" data-demo="registers" data-reveal>
        </figure>
      </div>
    </section>
    <section class="mt-section mt-section--alt" id="processes">
      <div class="container container-narrow">
        <div class="mt-act" data-reveal>
          <span class="mt-act__n mono">02</span>
          <div class="mt-act__body">
            <h2 class="mt-act__title">Processes, and the art of pretending</h2>
            <p class="mt-act__sub">
              One core, many programs. The OS fakes simultaneity by switching
              fast.
            </p>
          </div>
        </div>

        <p class="mt-prose" data-reveal>
          A running program is a <strong>process</strong>. The kernel tracks
          each one in a <em>Process Control Block</em> (PCB): its ID, its state,
          its memory, and — crucially — a saved copy of all the registers. With a
          single core, only one process runs at any instant. The illusion of “at
          the same time” comes from switching between them many times a second.
        </p>

        <h3 class="mt-h3" data-reveal>Context switching</h3>
        <p class="mt-prose" data-reveal>
          To switch, the CPU <strong>saves</strong> its registers into the current
          PCB, then <strong>restores</strong> the next process's registers from its
          PCB. Press play and watch a register set get parked and another swapped
          in:
        </p>
      </div>

      <div class="container">
        <figure class="mt-demo" data-demo="contextswitch" data-reveal>
          <div class="mt-demo__stage mt-demo__stage--wide">
            <canvas data-canvas></canvas>
          </div>
          <div class="mt-demo__panel">
            <p class="mt-demo__title">Context switch</p>
            <div class="mt-demo__actions">
              <button class="mt-btn" data-action="play">Switch processes</button
              >
              <button class="mt-btn mt-btn--ghost" data-action="reset"
                >Reset</button
              >
            </div>
            <p class="mt-demo__note" data-cs-note>
              Process 1 is running on the core.
            </p>
            <p class="mt-demo__note">
              This exact dance is the Linux <code>cpu_switch_to</code> routine below.
            </p>
          </div>
        </figure>
      </div>

      <div class="container container-narrow">
        <p class="mt-prose" data-reveal>
          It isn't hand-waving — here's the real ARM64 routine the Linux kernel
          runs to do it. Save the callee-saved registers of the previous task,
          load the next task's, and <code>ret</code> straight into it:
        </p>
        <pre class="mt-code" data-reveal><code>{codeSwitch}</code></pre>

        <h3 class="mt-h3" data-reveal>
          Creating a process: <code>fork()</code>
        </h3>
        <p class="mt-prose" data-reveal>
          <code>fork()</code> clones the current process whole — same code, same
          memory (copy-on-write), its own PCB. The twist: it returns
          <em>twice</em>. The child sees <code>0</code>; the parent sees the
          child's PID. Press the button to fork:
        </p>
      </div>

      <div class="container">
        <figure class="mt-demo" data-demo="fork" data-reveal>
          <div class="mt-demo__stage mt-demo__stage--wide">
            <canvas data-canvas></canvas>
          </div>
          <div class="mt-demo__panel">
            <p class="mt-demo__title">fork()</p>
            <div class="mt-demo__actions">
              <button class="mt-btn" data-action="fork">Call fork()</button>
              <button class="mt-btn mt-btn--ghost" data-action="reset"
                >Reset</button
              >
            </div>
            <p class="mt-demo__note" data-fork-note>
              One process, about to fork.
            </p>
          </div>
        </figure>
        <pre class="mt-code" data-reveal><code>{codeFork}</code></pre>
      </div>

      <div class="container container-narrow">
        <h3 class="mt-h3" data-reveal>And the truth: <code>clone()</code></h3>
        <p class="mt-prose" data-reveal>
          On Linux, <code>fork()</code> is really a thin wrapper over
          <code>clone()</code> — a system call that lets you choose precisely
          <em>what to share</em> with the new execution context:
        </p>
        <pre class="mt-code" data-reveal><code>{codeClone}</code></pre>
        <p class="mt-prose" data-reveal>
          Share nothing and you get a process. Share the memory space, file
          descriptors and signal handlers — and keep the same PID — and you get
          a
          <strong>thread</strong>. A thread isn't a special primitive; it's just
          <code>clone()</code> with the right flags. This is literally how glibc
          spawns a pthread:
        </p>
        <pre class="mt-code" data-reveal><code>{codeCloneFlags}</code></pre>
      </div>
    </section>
    <section class="mt-section" id="threads">
      <div class="container container-narrow">
        <div class="mt-act" data-reveal>
          <span class="mt-act__n mono">03</span>
          <div class="mt-act__body">
            <h2 class="mt-act__title">
              Threads share everything but the stack
            </h2>
            <p class="mt-act__sub">
              Many register-sets, one memory space — power and peril in one.
            </p>
          </div>
        </div>

        <p class="mt-prose" data-reveal>
          Threads live inside one process. They share its memory and resources,
          but each carries its own registers and stack so it can be scheduled
          independently. That shared memory is exactly why threads are fast to
          create and communicate — and exactly why they're dangerous. Toggle
          between the two models:
        </p>
      </div>

      <div class="container">
        <figure class="mt-demo" data-demo="memory" data-reveal>
          <div class="mt-demo__stage mt-demo__stage--wide">
            <canvas data-canvas></canvas>
          </div>
          <div class="mt-demo__panel">
            <p class="mt-demo__title">Memory model</p>
            <div class="mt-chips" data-memory-tabs>
              <button class="mt-chip is-active" data-kind="process"
                >Processes</button
              >
              <button class="mt-chip" data-kind="thread">Threads</button>
            </div>
            <p class="mt-demo__note" data-memory-note></p>
          </div>
        </figure>
        <pre class="mt-code" data-reveal><code>{codeThread}</code></pre>
      </div>

      <div class="container container-narrow">
        <h3 class="mt-h3" data-reveal>Thread-Local Storage</h3>
        <p class="mt-prose" data-reveal>
          If everything is shared, how can each thread keep its <em>own</em>
          value? Thread-Local Storage. The same <code>ThreadLocal</code> object used
          as a key returns a different value per thread — because the value actually
          lives in a map on the thread itself. Run it:
        </p>
      </div>

      <div class="container">
        <figure class="mt-demo" data-demo="threadlocal" data-reveal>
          <div class="mt-demo__stage mt-demo__stage--wide">
            <canvas data-canvas></canvas>
          </div>
          <div class="mt-demo__panel">
            <p class="mt-demo__title">Thread-Local explorer</p>
            <div class="mt-demo__actions">
              <button class="mt-btn" data-action="run">Run both threads</button>
              <button class="mt-btn mt-btn--ghost" data-action="reset"
                >Reset</button
              >
            </div>
            <p class="mt-demo__note" data-tl-note>
              Same key, different value per thread.
            </p>
          </div>
        </figure>
        <pre
          class="mt-code"
          data-reveal><code>{codeThreadLocalImpl}</code></pre>
      </div>
    </section>
    <section class="mt-section mt-section--alt" id="android">
      <div class="container container-narrow">
        <div class="mt-act" data-reveal>
          <span class="mt-act__n mono">04</span>
          <div class="mt-act__body">
            <h2 class="mt-act__title">Android is one big loop</h2>
            <p class="mt-act__sub">
              A thread, a queue, and a loop that never ends — that's the UI.
            </p>
          </div>
        </div>

        <p class="mt-prose" data-reveal>
          You rarely create raw threads on Android. Instead, work is posted as
          <strong>messages</strong> onto a <code>MessageQueue</code>, ordered by
          when they're due. A <code>Looper</code> spins forever, pulling the next
          ready message and handing it to a <code>Handler</code> to run. Post a few
          — immediate and delayed — and watch the loop drain them in time order:
        </p>
      </div>

      <!-- MessageQueue / Looper / Handler — centerpiece -->
      <div class="container">
        <figure
          class="mt-demo mt-demo--queue"
          data-demo="messagequeue"
          data-reveal
        >
          <div class="mt-demo__stage mt-demo__stage--wide">
            <canvas data-canvas></canvas>
          </div>
          <div class="mt-demo__panel">
            <p class="mt-demo__title">Looper · MessageQueue · Handler</p>
            <div class="mt-demo__actions">
              <button class="mt-btn" data-action="post">post()</button>
              <button class="mt-btn" data-action="postDelayed"
                >postDelayed()</button
              >
            </div>
            <div class="mt-demo__actions">
              <button
                class="mt-btn mt-btn--ghost"
                data-action="toggle"
                data-looping="true">Pause loop</button
              >
              <button class="mt-btn mt-btn--ghost" data-action="reset"
                >Reset</button
              >
            </div>
            <p class="mt-demo__note" data-mq-note>
              The Looper is idle, waiting for messages.
            </p>
          </div>
        </figure>
      </div>

      <div class="container container-narrow">
