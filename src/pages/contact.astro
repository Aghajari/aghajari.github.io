---
import Base from "@layouts/Base.astro";
import PageHero from "@components/PageHero.astro";
import Icon from "@components/Icon.astro";
import { profile } from "@data/profile";

const email = profile.socials.email.replace("mailto:", "");

// All channels are equal — pick whichever you like.
const channels = [
  { name: "Telegram", handle: "@theAghajari", href: profile.socials.telegram, icon: "telegram", note: "Quick chats & questions", accent: "#2aabee" },
  { name: "GitHub", handle: `@${profile.githubUser}`, href: profile.socials.github, icon: "github", note: "Code, libraries & issues", accent: "#a78bfa" },
  { name: "Medium", handle: "@aghajari", href: profile.socials.medium, icon: "medium", note: "Articles & deep dives", accent: "#34d399" },
  { name: "LinkedIn", handle: "amir-aghajari", href: profile.socials.linkedin, icon: "linkedin", note: "Professional network", accent: "#38bdf8" },
] as const;
---

<Base
  title="Contact"
  description="Say hello to AmirHossein Aghajari — always happy to talk UI engineering, graphics, performance, open source and speaking."
>
  <PageHero
    eyebrow="Say hello"
    title="Let's talk"
    intro="I love a good engineering conversation — UI, graphics, performance, open source, or a talk. No agenda needed; reach out on whichever channel feels easiest."
  />

  <section class="section">
    <div class="container container-narrow">
      <div class="contact-grid">
        {channels.map((c) => (
          <a
            href={c.href}
            target="_blank"
            rel="noopener"
            class="contact-card sheen"
            style={`--ch:${c.accent}`}
            data-reveal
          >
            <span class="cc-glow" aria-hidden="true"></span>
            <span class="cc-icon"><Icon name={c.icon} size={24} /></span>
            <div class="cc-text">
              <span class="cc-name">{c.name}</span>
              <span class="cc-handle mono">{c.handle}</span>
              <span class="cc-note">{c.note}</span>
            </div>
            <Icon name="arrow-up-right" size={18} class="cc-arrow" />
          </a>
        ))}
      </div>

      <!-- Email -->
      <a href={profile.socials.email} class="contact-email sheen" data-reveal>
        <span class="ce-icon"><Icon name="mail" size={20} /></span>
        <div class="ce-text">
          <span class="ce-label">Prefer email?</span>
          <span class="ce-addr mono">{email}</span>
        </div>
        <Icon name="arrow-up-right" size={18} class="ce-arrow" />
      </a>
    </div>
  </section>
</Base>

<style>
  /* ---------- Channels (all equal, premium) ---------- */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }
  .contact-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--ch) 5%, var(--surface)), var(--surface));
    transition: border-color var(--dur-mid) var(--ease-out), transform var(--dur-mid) var(--ease-out),
      box-shadow var(--dur-mid) var(--ease-out);
  }
  .contact-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--ch) 50%, var(--border));
    box-shadow: 0 22px 50px -30px color-mix(in srgb, var(--ch) 80%, transparent);
  }
  /* soft corner glow on hover */
  .cc-glow {
    position: absolute;
    inset: -50% 50% auto -30%;
    height: 130%;
    z-index: -1;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--ch) 22%, transparent), transparent);
    opacity: 0;
    filter: blur(24px);
    transition: opacity var(--dur-mid) var(--ease-out);
    pointer-events: none;
  }
  .contact-card:hover .cc-glow { opacity: 1; }

  .cc-icon {
    display: grid; place-items: center; flex-shrink: 0;
    width: 52px; height: 52px; border-radius: var(--radius-md);
    color: color-mix(in srgb, var(--ch) 75%, var(--text));
    background: color-mix(in srgb, var(--ch) 12%, var(--surface-2));
    border: 1px solid color-mix(in srgb, var(--ch) 26%, var(--border));
    transition: color var(--dur-mid), background-color var(--dur-mid), border-color var(--dur-mid),
      transform var(--dur-mid) var(--ease-out);
  }
  .contact-card:hover .cc-icon {
    color: #fff;
    background: linear-gradient(135deg, color-mix(in srgb, var(--ch) 92%, #fff), var(--ch));
    border-color: transparent;
    transform: scale(1.04);
  }

  .cc-text { display: flex; flex-direction: column; gap: 0.12rem; min-width: 0; }
  .cc-name { font-weight: 600; letter-spacing: -0.01em; }
  .cc-handle { font-size: 0.85rem; color: var(--text-2); }
  .cc-note { font-size: 0.78rem; color: var(--text-3); margin-top: 0.15rem; }

  .cc-arrow {
    position: absolute; top: var(--space-5); right: var(--space-5);
    color: var(--text-3);
    transition: transform var(--dur-fast) var(--ease-out), color var(--dur-fast);
  }
  .contact-card:hover .cc-arrow { transform: translate(2px, -2px); color: color-mix(in srgb, var(--ch) 70%, var(--text)); }

  /* ---------- Email ---------- */
  .contact-email {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-5);
    padding: var(--space-5) var(--space-6);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background:
      radial-gradient(120% 180% at 100% 0%, color-mix(in srgb, var(--accent) 8%, transparent), transparent 55%),
      var(--surface);
    transition: border-color var(--dur-mid) var(--ease-out), transform var(--dur-mid) var(--ease-out),
      box-shadow var(--dur-mid) var(--ease-out);
  }
  .contact-email:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    box-shadow: 0 18px 44px -28px color-mix(in srgb, var(--accent) 50%, transparent);
  }
  .ce-icon {
    display: grid; place-items: center; flex-shrink: 0;
    width: 52px; height: 52px; border-radius: var(--radius-md);
    background: var(--surface-2); border: 1px solid var(--border); color: var(--text-2);
    transition: color var(--dur-mid), background-color var(--dur-mid), border-color var(--dur-mid);
  }
  .contact-email:hover .ce-icon {
    color: #fff;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 92%, #fff), var(--accent));
    border-color: transparent;
  }
  .ce-text { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .ce-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .ce-addr { font-size: var(--step-1); color: var(--text); }
  .ce-arrow {
    margin-left: auto;
    flex-shrink: 0;
    color: var(--text-3);
    transition: transform var(--dur-fast) var(--ease-out), color var(--dur-fast);
  }
  .contact-email:hover .ce-arrow { transform: translate(2px, -2px); color: var(--text); }

  @media (max-width: 620px) {
    .contact-grid { grid-template-columns: 1fr; }
    .contact-email { padding: var(--space-5); }
  }
</style>
