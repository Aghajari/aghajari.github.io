---
import { profile } from "@data/profile";

interface Props {
  size?: number;
  class?: string;
}
const { size = 32, class: cls = "" } = Astro.props;
const avatarUrl = `https://github.com/${profile.githubUser}.png`;
---

<img
  src={avatarUrl}
  alt=""
  width={size}
  height={size}
  class:list={["profile-avatar", cls]}
  loading="eager"
  decoding="async"
/>

<style>
  .profile-avatar {
    display: block;
    flex-shrink: 0;
    border-radius: 9px;
    object-fit: cover;
    border: 1px solid var(--border-strong);
    background: var(--surface-2);
    box-shadow: 0 4px 16px -8px color-mix(in srgb, var(--bg) 55%, transparent);
  }
  :global(.profile-avatar--lg) {
    width: 40px;
    height: 40px;
    border-radius: 11px;
  }
</style>
