---
import type { ThemeKey } from "@/lib/themes";
import { themeVars } from "@/lib/themes";
interface Props {
  theme: ThemeKey;
  class?: string;
}
const { theme, class: cls = "" } = Astro.props;
---

<div class:list={["tv", `tv--${theme}`, cls]} style={themeVars(theme)} aria-hidden="true">
  {theme === "shader" && (
    <div class="tv-shader">
      <span class="ring r1"></span>
      <span class="ring r2"></span>
      <span class="ring r3"></span>
      <span class="glass"></span>
    </div>
  )}
  {theme === "motion" && (
    <div class="tv-motion">
      <svg viewBox="0 0 200 120" preserveAspectRatio="none">
        <path class="curve" d="M0 100 C 60 100, 60 20, 120 20 S 200 20, 200 20" />
      </svg>
      <span class="dot d1"></span>
      <span class="dot d2"></span>
      <span class="dot d3"></span>
    </div>
  )}
  {theme === "compose" && (
    <div class="tv-compose">
      <span class="layer l1"></span>
      <span class="layer l2"></span>
      <span class="layer l3"></span>
    </div>
  )}
  {theme === "systems" && (
    <div class="tv-systems">
      <span class="line ln1"></span>
      <span class="line ln2"></span>
      <span class="line ln3"></span>
      <span class="node n1"></span>
      <span class="node n2"></span>
    </div>
  )}
  {theme === "audio" && (
    <div class="tv-audio">
      {Array.from({ length: 14 }).map((_, i) => (
        <span class="bar" style={`--n:${i}`}></span>
      ))}
    </div>
  )}
  {theme === "academic" && (
    <div class="tv-academic">
      <span class="page p1"></span>
      <span class="page p2"></span>
      <span class="page p3"></span>
      <span class="mark"></span>
    </div>
  )}
  <span class="tv-grain"></span>
</div>

<style>
  .tv {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: inherit;
    background:
      radial-gradient(120% 120% at 80% 0%, color-mix(in srgb, var(--t2) 26%, transparent), transparent 60%),
      radial-gradient(120% 120% at 0% 100%, color-mix(in srgb, var(--t1) 22%, transparent), transparent 60%),
      var(--media-base);
    isolation: isolate;
  }
  .tv-grain {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 4px 4px;
    opacity: 0.4;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  /* ---- shader: refraction rings + glass ---- */
  .tv-shader { position: absolute; inset: 0; display: grid; place-items: center; }
  .tv-shader .ring {
    position: absolute;
    border-radius: 50%;
    border: 1.5px solid color-mix(in srgb, var(--t3) 55%, transparent);
    filter: blur(0.3px);
    animation: pulse-ring 7s var(--ease-in-out) infinite;
  }
  .r1 { width: 38%; aspect-ratio: 1; }
  .r2 { width: 60%; aspect-ratio: 1; animation-delay: -2.3s; opacity: 0.6; }
  .r3 { width: 82%; aspect-ratio: 1; animation-delay: -4.6s; opacity: 0.35; }
  .tv-shader .glass {
    position: absolute;
    width: 34%;
    aspect-ratio: 1;
    border-radius: 30%;
    background: linear-gradient(135deg, color-mix(in srgb, var(--t1) 70%, transparent), color-mix(in srgb, var(--t2) 70%, transparent));
    box-shadow: inset 0 0 30px rgba(255,255,255,0.25), 0 20px 60px -20px var(--t2);
    backdrop-filter: blur(4px);
    animation: float-soft 8s var(--ease-in-out) infinite;
  }
  @keyframes pulse-ring {
    0%, 100% { transform: scale(1); opacity: var(--o, 0.5); }
    50% { transform: scale(1.06); opacity: 0.8; }
  }

  /* ---- motion: easing curve + travelling dots ---- */
  .tv-motion { position: absolute; inset: 0; }
  .tv-motion svg { position: absolute; inset: 10% 8%; width: 84%; height: 80%; overflow: visible; }
  .tv-motion .curve {
    fill: none;
    stroke: color-mix(in srgb, var(--t2) 70%, transparent);
    stroke-width: 1.5;
    stroke-dasharray: 4 5;
    opacity: 0.7;
  }
  .tv-motion .dot {
    position: absolute;
    width: 12px; height: 12px; border-radius: 50%;
    background: var(--t1);
    box-shadow: 0 0 22px var(--t2);
    top: 50%; left: 0;
    animation: travel 5s var(--ease-in-out) infinite;
  }
  .d2 { background: var(--t2); animation-delay: -1.6s; }
  .d3 { background: var(--t3); animation-delay: -3.2s; }
  @keyframes travel {
    0% { transform: translate(8%, 70px) scale(0.7); opacity: 0; }
    25% { opacity: 1; }
    100% { transform: translate(640%, -40px) scale(1.1); opacity: 0; }
  }

  /* ---- compose: stacked layers ---- */
  .tv-compose { position: absolute; inset: 0; display: grid; place-items: center; perspective: 800px; }
  .tv-compose .layer {
    position: absolute;
    width: 46%; height: 30%;
    border-radius: 14px;
    border: 1px solid color-mix(in srgb, var(--t3) 40%, transparent);
    background: color-mix(in srgb, var(--t1) 14%, var(--surface));
    box-shadow: var(--shadow-md);
    animation: layer-float 9s var(--ease-in-out) infinite;
  }
  .l1 { transform: translate(-16%, 18%) rotateX(8deg) rotateZ(-4deg); background: color-mix(in srgb, var(--t1) 22%, var(--surface)); }
  .l2 { transform: translate(0, 0) rotateX(8deg) rotateZ(-4deg); animation-delay: -1.5s; }
  .l3 { transform: translate(16%, -18%) rotateX(8deg) rotateZ(-4deg); animation-delay: -3s; background: color-mix(in srgb, var(--t3) 16%, var(--surface)); }
  @keyframes layer-float {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -8px; }
  }

  /* ---- systems: circuit traces ---- */
  .tv-systems { position: absolute; inset: 12%; }
  .tv-systems .line {
    position: absolute; height: 2px; border-radius: 2px;
    background: linear-gradient(90deg, transparent, var(--t2), transparent);
    background-size: 200% 100%;
    animation: trace 3.5s linear infinite;
  }
  .ln1 { top: 25%; left: 0; right: 0; }
  .ln2 { top: 55%; left: 0; right: 0; animation-delay: -1.2s; }
  .ln3 { top: 80%; left: 0; right: 0; animation-delay: -2.1s; }
  .tv-systems .node {
    position: absolute; width: 14px; height: 14px; border-radius: 4px;
    border: 1.5px solid var(--t1);
    background: color-mix(in srgb, var(--t1) 30%, transparent);
  }
  .n1 { top: calc(25% - 6px); left: 30%; }
  .n2 { top: calc(55% - 6px); left: 64%; }
  @keyframes trace { from { background-position: 200% 0; } to { background-position: -200% 0; } }

  /* ---- audio: equalizer ---- */
  .tv-audio {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    gap: 5px; padding: 18%;
  }
  .tv-audio .bar {
    width: 7px; border-radius: 4px; height: 20%;
    background: linear-gradient(var(--t3), var(--t1));
    animation: eq 1.4s var(--ease-in-out) infinite;
    animation-delay: calc(var(--n) * -0.11s);
  }
  @keyframes eq {
    0%, 100% { height: 16%; }
    50% { height: 78%; }
  }

  /* ---- academic: editorial pages ---- */
  .tv-academic {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    perspective: 900px;
  }
  .tv-academic .page {
    position: absolute;
    width: 42%;
    height: 54%;
    border-radius: 10px 14px 14px 10px;
    border: 1px solid color-mix(in srgb, var(--t1) 35%, transparent);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--t1) 18%, var(--surface)), color-mix(in srgb, var(--t3) 10%, var(--surface)));
    box-shadow: var(--shadow-md);
    animation: page-float 10s var(--ease-in-out) infinite;
  }
  .tv-academic .page::before {
    content: "";
    position: absolute;
    top: 18%;
    left: 14%;
    right: 14%;
    height: 2px;
    border-radius: 2px;
    background: color-mix(in srgb, var(--t2) 35%, transparent);
    box-shadow:
      0 10px 0 color-mix(in srgb, var(--t2) 22%, transparent),
      0 20px 0 color-mix(in srgb, var(--t2) 14%, transparent),
      0 30px 0 color-mix(in srgb, var(--t2) 10%, transparent);
  }
  .p1 { transform: translate(-22%, 10%) rotate(-7deg); }
  .p2 { transform: translate(0, -4%) rotate(2deg); animation-delay: -2.5s; z-index: 1; }
  .p3 { transform: translate(20%, 12%) rotate(8deg); animation-delay: -5s; }
  .tv-academic .mark {
    position: absolute;
    top: 22%;
    right: 28%;
    width: 10px;
    height: 28px;
    border-radius: 2px 6px 6px 2px;
    background: linear-gradient(var(--t2), var(--t1));
    box-shadow: 0 6px 18px color-mix(in srgb, var(--t2) 45%, transparent);
    transform: rotate(12deg);
    animation: mark-sway 6s var(--ease-in-out) infinite;
  }
  @keyframes page-float {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -6px; }
  }
  @keyframes mark-sway {
    0%, 100% { transform: rotate(12deg) translateY(0); }
    50% { transform: rotate(8deg) translateY(-4px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .tv * { animation: none !important; }
  }
</style>
