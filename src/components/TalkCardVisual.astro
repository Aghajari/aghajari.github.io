---
import type { ThemeKey } from "@/lib/themes";
import ThemeVisual from "./ThemeVisual.astro";

interface Props {
  talkId: string;
  theme: ThemeKey;
}

const { talkId, theme } = Astro.props;

const CUSTOM_VISUALS = new Set([
  "complex-animations",
  "multi-threading",
  "navigating-ce-studies",
]);
const isCustom = CUSTOM_VISUALS.has(talkId);
---

<div
  class:list={["tcv", `tcv--${talkId}`, { "tcv--custom": isCustom }]}
  data-tcv={isCustom ? talkId : undefined}
>
  {
    isCustom ? (
      <>
        <canvas class="tcv__canvas" data-tcv-canvas aria-hidden="true" />
        <span class="tcv__veil" aria-hidden="true" />
      </>
    ) : (
      <ThemeVisual theme={theme} />
    )
  }
</div>

<style>
  .tcv {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: var(--media-base);
  }

  .tcv__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .tcv__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  /* Complex Animations — same veil as the talk hero */
  .tcv--complex-animations .tcv__veil {
    background:
      radial-gradient(
        120% 90% at 75% 18%,
        color-mix(in srgb, var(--t2) 14%, transparent),
        transparent 60%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--media-ink) 28%, transparent) 0%,
        transparent 34%,
        color-mix(in srgb, var(--media-ink) 72%, transparent) 88%,
        var(--media-base) 100%
      );
  }

  /* Multi-Threading — same veil as the talk hero */
  .tcv--multi-threading .tcv__veil {
    background:
      radial-gradient(
        120% 90% at 78% 16%,
        color-mix(in srgb, var(--t2) 14%, transparent),
        transparent 60%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--media-ink) 28%, transparent) 0%,
        transparent 34%,
        color-mix(in srgb, var(--media-ink) 74%, transparent) 88%,
        var(--media-base) 100%
      );
  }

  /* Navigating CE Studies — terminal glow */
  .tcv--navigating-ce-studies .tcv__veil {
    background:
      radial-gradient(
        80% 70% at 88% 8%,
        color-mix(in srgb, var(--t1) 16%, transparent),
        transparent 60%
      ),
      radial-gradient(
        70% 80% at 4% 92%,
        color-mix(in srgb, var(--t3) 12%, transparent),
        transparent 60%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--media-ink) 18%, transparent) 0%,
        transparent 42%
      ),
      linear-gradient(
        180deg,
        transparent 55%,
        color-mix(in srgb, var(--media-base) 88%, transparent) 100%
      );
  }
</style>

<script src="../scripts/talk-card-visuals.ts"></script>
