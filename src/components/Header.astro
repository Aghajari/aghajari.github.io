---
import { primaryNav, profile } from "@data/profile";
import Icon from "./Icon.astro";
import ProfileAvatar from "./ProfileAvatar.astro";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
function isActive(href: string) {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
}
---

<header class="site-header" id="site-header">
  <div class="header-backdrop" aria-hidden="true"></div>
  <div class="header-inner container-wide">
    <a href="/" class="brand" aria-label={`${profile.name} — home`}>
      <ProfileAvatar size={32} />
      <span class="brand-name">{profile.shortName} <span class="brand-last">Aghajari</span></span>
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      {primaryNav.map((item) => (
        <a
          href={item.href}
          class:list={["nav-link", { active: isActive(item.href) }]}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <button
        class="theme-toggle"
        id="theme-toggle"
        type="button"
        aria-label="Toggle color theme"
      >
        <span class="ic-sun"><Icon name="sun" size={18} /></span>
        <span class="ic-moon"><Icon name="moon" size={18} /></span>
      </button>
      <button
        class="menu-btn"
        id="menu-btn"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="ic-menu" aria-hidden="true"><Icon name="menu" size={20} /></span>
        <span class="ic-close" aria-hidden="true"><Icon name="close" size={20} /></span>
      </button>
    </div>
  </div>

  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <button class="mobile-nav__backdrop" id="mobile-nav-backdrop" type="button" tabindex="-1" aria-label="Close menu"></button>
    <div class="mobile-nav__panel">
      <nav class="mobile-nav__links" aria-label="Mobile">
        {primaryNav.map((item, i) => (
          <a
            href={item.href}
            class:list={["mobile-link", { active: isActive(item.href) }]}
            style={`--i:${i}`}
          >
            <span class="mobile-link__label">{item.label}</span>
            <Icon name="arrow" size={18} class="mobile-link__arrow" />
          </a>
        ))}
      </nav>
      <div class="mobile-nav__foot">
        <p class="mobile-nav__tagline muted">{profile.tagline}</p>
        <div class="mobile-socials">
          <a href={profile.socials.github} target="_blank" rel="noopener" aria-label="GitHub"><Icon name="github" /></a>
          <a href={profile.socials.medium} target="_blank" rel="noopener" aria-label="Medium"><Icon name="medium" /></a>
          <a href={profile.socials.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn"><Icon name="linkedin" /></a>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    isolation: isolate;
  }

  /* Frosted backdrop — solid tint underneath; glass layer on top when supported */
  .header-backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .header-backdrop::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--header-tint);
    border-bottom: 1px solid transparent;
    transition: opacity var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  .header-backdrop::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--header-glass);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-fast) var(--ease-out);
  }

  @supports (
    (-webkit-backdrop-filter: blur(1px)) or (backdrop-filter: blur(1px))
  ) {
    .header-backdrop::before {
      opacity: 0;
    }
  }

  @supports not (
    (-webkit-backdrop-filter: blur(1px)) or (backdrop-filter: blur(1px))
  ) {
    .header-backdrop::after {
      display: none;
    }
    .header-backdrop::before {
      opacity: 1;
    }
  }

  .site-header.scrolled .header-backdrop,
  .site-header.menu-open .header-backdrop {
    opacity: 1;
  }

  .site-header.scrolled .header-backdrop::before,
  .site-header.scrolled .header-backdrop::after,
  .site-header.menu-open .header-backdrop::before,
  .site-header.menu-open .header-backdrop::after {
    border-bottom-color: var(--border);
  }

  .header-inner {
    position: relative;
    z-index: 2;
    height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    min-width: 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    font-size: 0.98rem;
    min-width: 0;
    flex-shrink: 1;
  }
  .brand-name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .brand-last { color: var(--text-2); font-weight: 500; }
  .brand:hover .brand-last { color: var(--text); }

  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  .nav-link {
    position: relative;
    padding: 0.5rem 0.85rem;
    font-size: 0.9rem;
    color: var(--text-2);
    border-radius: var(--radius-pill);
    transition: color var(--dur-fast) var(--ease-out), background-color var(--dur-fast);
  }
  .nav-link:hover { color: var(--text); }
  .nav-link.active { color: var(--text); }
  .nav-link.active::after {
    content: "";
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-shrink: 0;
  }
  .theme-toggle,
  .menu-btn {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    transition: background-color var(--dur-fast), border-color var(--dur-fast), transform var(--dur-fast);
  }
  .theme-toggle:hover,
  .menu-btn:hover { background: var(--surface-hover); border-color: var(--border-strong); }
  .theme-toggle:active,
  .menu-btn:active { transform: scale(0.92); }
  .theme-toggle { position: relative; overflow: hidden; }
  .menu-btn {
    display: none;
    position: relative;
    overflow: hidden;
  }
  .ic-sun, .ic-moon,
  .ic-menu, .ic-close {
    position: absolute;
    display: grid;
    place-items: center;
    transition: transform var(--dur-mid) var(--ease-spring), opacity var(--dur-fast);
  }
  :global([data-theme="dark"]) .ic-sun { transform: translateY(0) rotate(0); opacity: 1; }
  :global([data-theme="dark"]) .ic-moon { transform: translateY(140%); opacity: 0; }
  :global([data-theme="light"]) .ic-sun { transform: translateY(-140%); opacity: 0; }
  :global([data-theme="light"]) .ic-moon { transform: translateY(0); opacity: 1; }

  .ic-menu { transform: rotate(0deg) scale(1); opacity: 1; }
  .ic-close { transform: rotate(-90deg) scale(0.75); opacity: 0; }
  .site-header.menu-open .ic-menu { transform: rotate(90deg) scale(0.75); opacity: 0; }
  .site-header.menu-open .ic-close { transform: rotate(0deg) scale(1); opacity: 1; }

  /* ---------- Mobile menu — fixed sheet below header ---------- */
  .mobile-nav {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    visibility: hidden;
  }
  .mobile-nav.open {
    pointer-events: auto;
    visibility: visible;
  }

  .mobile-nav__backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    padding: 0;
    margin: 0;
    cursor: pointer;
    background: color-mix(in srgb, var(--bg) 55%, transparent);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    opacity: 0;
    transition: opacity var(--dur-mid) var(--ease-out);
  }
  .mobile-nav.open .mobile-nav__backdrop {
    opacity: 1;
  }

  .mobile-nav__panel {
    position: absolute;
    top: var(--header-h);
    left: 0;
    right: 0;
    max-height: calc(100dvh - var(--header-h));
    display: flex;
    flex-direction: column;
    padding: var(--space-4) var(--gutter) max(var(--space-6), env(safe-area-inset-bottom));
    border-bottom: 1px solid var(--border);
    background: var(--header-tint);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    backdrop-filter: blur(24px) saturate(180%);
    box-shadow: var(--shadow-lg);
    overflow-y: auto;
    overscroll-behavior: contain;
    transform: translateY(-10px);
    opacity: 0;
    transition:
      transform var(--dur-mid) var(--ease-out),
      opacity var(--dur-mid) var(--ease-out);
  }
  .mobile-nav.open .mobile-nav__panel {
    transform: translateY(0);
    opacity: 1;
  }

  .mobile-nav__links {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    min-height: 3.25rem;
    padding: 0.65rem 0.85rem;
    border-radius: var(--radius-md);
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--text-2);
    border: 1px solid transparent;
    opacity: 0;
    transform: translateY(6px);
    transition:
      color var(--dur-fast),
      background-color var(--dur-fast),
      border-color var(--dur-fast),
      opacity 0.45s var(--ease-out),
      transform 0.45s var(--ease-out);
    transition-delay: calc(50ms + var(--i, 0) * 35ms);
  }
  .mobile-nav.open .mobile-link {
    opacity: 1;
    transform: none;
  }
  .mobile-link:hover,
  .mobile-link:focus-visible {
    color: var(--text);
    background: var(--surface-hover);
    border-color: var(--border);
  }
  .mobile-link.active {
    color: var(--text);
    background: color-mix(in srgb, var(--accent) 7%, var(--surface));
    border-color: color-mix(in srgb, var(--accent) 22%, var(--border));
  }
  .mobile-link__label { flex: 1; min-width: 0; }
  .mobile-link :global(.mobile-link__arrow) {
    flex-shrink: 0;
    color: var(--text-3);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity var(--dur-fast), transform var(--dur-fast), color var(--dur-fast);
  }
  .mobile-link.active :global(.mobile-link__arrow),
  .mobile-link:hover :global(.mobile-link__arrow) {
    opacity: 1;
    transform: translateX(0);
    color: var(--accent);
  }

  .mobile-nav__foot {
    margin-top: auto;
    padding-top: var(--space-6);
    border-top: 1px solid var(--border);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.45s var(--ease-out) 0.2s, transform 0.45s var(--ease-out) 0.2s;
  }
  .mobile-nav.open .mobile-nav__foot {
    opacity: 1;
    transform: none;
  }
  .mobile-nav__tagline {
    font-size: 0.88rem;
    line-height: 1.45;
    margin-bottom: var(--space-4);
  }
  .mobile-socials {
    display: flex;
    gap: var(--space-3);
    color: var(--text-2);
  }
  .mobile-socials a {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--surface);
    transition: color var(--dur-fast), border-color var(--dur-fast), transform var(--dur-fast);
  }
  .mobile-socials a:hover {
    color: var(--text);
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }

  @media (max-width: 980px) {
    .nav-desktop { display: none; }
    .menu-btn { display: grid; }
    /* Solid header bar on mobile — easier to read over hero imagery */
    .header-backdrop { opacity: 1; }
    .header-backdrop::before,
    .header-backdrop::after { border-bottom-color: var(--border); }
  }

  @media (max-width: 520px) {
    .brand-last { display: none; }
  }

  @media (max-width: 380px) {
    .brand-name { display: none; }
    .theme-toggle,
    .menu-btn { width: 36px; height: 36px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-link,
    .mobile-nav__foot,
    .mobile-nav__panel,
    .mobile-nav__backdrop {
      transition-duration: 0.001ms !important;
      transition-delay: 0ms !important;
      transform: none !important;
      opacity: 1 !important;
    }
    .mobile-nav:not(.open) .mobile-link,
    .mobile-nav:not(.open) .mobile-nav__foot {
      opacity: 0;
    }
  }
</style>
