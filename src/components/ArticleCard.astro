---
import type { CollectionEntry } from "astro:content";
import PublicationCover from "./PublicationCover.astro";
import ThemeVisual from "./ThemeVisual.astro";
import { themes, formatDate } from "@/lib/themes";
import { getPublicationCover } from "@/lib/publications";
import Icon from "./Icon.astro";

interface Props {
  entry: CollectionEntry<"publications">;
  feature?: boolean;
}
const { entry, feature = false } = Astro.props;
const { data } = entry;
const t = themes[data.theme];
const cover = getPublicationCover(entry);
---

<a
  href={`/publications/${entry.id}`}
  class:list={["article-card", "card", "sheen", { feature }]}
  data-reveal
>
  <div class="ac-visual">
    {
      cover ? (
        <PublicationCover
          src={cover.local}
          alt={cover.alt}
          theme={data.theme}
          variant="card"
        />
      ) : (
        <ThemeVisual theme={data.theme} />
      )
    }
    <span class="ac-domain">{t.label}</span>
  </div>
  <div class="ac-body">
    <div class="ac-meta">
      <span>{formatDate(data.date)}</span>
      <span class="dot-sep">·</span>
      <span>{data.readingTime} min read</span>
      {
        data.series && (
          <>
            <>
              <span class="dot-sep">·</span>
              <span class="ac-series">{data.series}</span>
            </>
          </>
        )
      }
    </div>
    <h3 class="ac-title">{data.title}</h3>
    <p class="ac-summary muted">{data.subtitle}</p>
    <span class="ac-cta">
      Read preview <Icon name="arrow" size={16} class="arrow" />
    </span>
  </div>
</a>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    height: 100%;
  }
  .ac-visual {
    position: relative;
    aspect-ratio: 16 / 10;
    border-bottom: 1px solid var(--border);
  }
  .feature .ac-visual {
    aspect-ratio: 16 / 8;
  }
  .ac-domain {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    z-index: 6;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3em 0.7em;
    border-radius: var(--radius-pill);
    background: var(--media-chrome-bg);
    backdrop-filter: blur(10px);
    border: 1px solid var(--media-chrome-border);
    color: var(--media-chrome-text);
    box-shadow: 0 4px 20px var(--media-chrome-shadow);
  }
  .ac-body {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: var(--space-5);
    flex: 1;
  }
  .ac-meta {
    display: flex;
    align-items: center;
    gap: 0.5em;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-3);
  }
  .ac-series {
    color: var(--accent);
  }
  .dot-sep {
    opacity: 0.5;
  }
  .ac-title {
    font-size: var(--step-2);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .feature .ac-title {
    font-size: var(--step-3);
  }
  .ac-summary {
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .ac-cta {
    margin-top: auto;
    padding-top: var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-size: 0.88rem;
    color: var(--text);
  }
  .ac-cta .arrow {
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .article-card:hover .ac-cta .arrow {
    transform: translateX(4px);
  }

  .article-card:hover :global(.pub-cover__img) {
    transform: scale(1.06);
    filter: saturate(0.86) brightness(0.88) contrast(1.04);
  }

  @media (min-width: 880px) {
    .feature {
      flex-direction: row;
    }
    .feature .ac-visual {
      aspect-ratio: auto;
      width: 52%;
      border-bottom: none;
      border-right: 1px solid var(--border);
    }
    .feature .ac-body {
      width: 48%;
      justify-content: center;
      padding: var(--space-7);
    }
  }
</style>
