---
import Book3D from "./Book3D.astro";
import { ratingStars, readingDateSortKey, type Book } from "@data/reading";

interface Props {
  book: Book;
}
const { book } = Astro.props;
const stars = ratingStars(book.rating);
const href = `/reading/${book.slug}`;
---

<a
  class="book-card"
  href={href}
  data-book-card
  data-sort-reading={readingDateSortKey(book.readingDate)}
  data-sort-title={book.title.toLowerCase()}
  data-sort-author={book.author.toLowerCase()}
  data-sort-rating={book.rating}
  data-sort-published={book.year}
  aria-label={`${book.title} by ${book.author}`}
>
  <div class="book-card__stage">
    <Book3D
      cover={book.cover}
      title={book.title}
      author={book.author}
      spine={book.spine}
      variant="shelf"
      transitionName={`book-${book.slug}`}
    />
    <span class="book-card__shelf" aria-hidden="true"></span>
  </div>
  <div class="book-card__meta">
    <h3 class="book-card__title serif">{book.title}</h3>
    <p class="book-card__author">{book.author}</p>
    <div class="book-card__stars" aria-label={`Rated ${book.rating} out of 5`}>
      {stars.map((s) => (
        <span class:list={["bc-star", `bc-star--${s}`]}>★</span>
      ))}
    </div>
  </div>
</a>

<style>
  .book-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-3) var(--space-3);
    border-radius: var(--radius-lg);
    text-align: center;
    color: inherit;
    transition: transform 0.5s var(--ease-out);
  }

  .book-card__stage {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    padding-bottom: 14px;
  }

  /* the shelf ledge each book rests on */
  .book-card__shelf {
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 86%;
    height: 10px;
    transform: translateX(-50%);
    border-radius: 2px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--surface-2) 92%, var(--text)) 0%,
      var(--surface) 60%,
      color-mix(in srgb, var(--surface) 80%, #000) 100%
    );
    box-shadow:
      0 1px 0 var(--surface-highlight, rgba(255, 255, 255, 0.4)),
      0 10px 18px -10px rgba(0, 0, 0, 0.45);
    opacity: 0.9;
  }

  .book-card__meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }
  .book-card__title {
    font-size: 1.02rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--text);
    transition: color var(--dur-fast);
  }
  .book-card__author {
    font-size: 0.82rem;
    color: var(--text-3);
  }
  .book-card__stars {
    margin-top: 0.25rem;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    line-height: 1;
  }
  .bc-star {
    color: color-mix(in srgb, var(--text) 16%, transparent);
  }
  .bc-star--full {
    color: var(--accent, #d8a657);
  }
  .bc-star--half {
    background: linear-gradient(
      90deg,
      var(--accent, #d8a657) 50%,
      color-mix(in srgb, var(--text) 16%, transparent) 50%
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .book-card { --accent: #d8a657; }

  .book-card:hover .book-card__title {
    color: color-mix(in srgb, var(--text) 70%, var(--accent-strong, #b8732f));
  }

  @media (prefers-reduced-motion: reduce) {
    .book-card { transition: none; }
  }
</style>
