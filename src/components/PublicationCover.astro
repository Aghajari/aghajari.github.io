---
import type { ThemeKey } from "@/lib/themes";
import { themeVars } from "@/lib/themes";
import ThemeVisual from "./ThemeVisual.astro";

interface Props {
  src: string;
  alt: string;
  theme: ThemeKey;
  variant?: "card" | "hero" | "plain";
}
const { src, alt, theme, variant = "card" } = Astro.props;
const plain = variant === "plain";
---

<div
  class:list={["pub-cover", `pub-cover--${variant}`]}
  style={plain ? undefined : themeVars(theme)}
>
  <img
    class="pub-cover__img"
    src={src}
    alt={alt}
    loading={variant === "hero" ? "eager" : "lazy"}
    decoding="async"
    fetchpriority={variant === "hero" ? "high" : "auto"}
  />
  {
    !plain && (
      <>
        <div class="pub-cover__tint" aria-hidden="true" />
        <div class="pub-cover__scrim" aria-hidden="true" />
        <div class="pub-cover__fx" aria-hidden="true">
          <ThemeVisual theme={theme} />
        </div>
        <div class="pub-cover__grain" aria-hidden="true" />
        <div class="pub-cover__vignette" aria-hidden="true" />
      </>
    )
  }
</div>

<style>
  .pub-cover {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    isolation: isolate;
    background: var(--media-base);
  }

  .pub-cover__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.02);
    filter: saturate(0.82) brightness(0.86) contrast(1.04);
    transition:
      transform 1.1s var(--ease-out),
      filter 0.6s var(--ease-out);
    will-change: transform;
  }

  /* Theme-colored wash — kept subtle so Medium cover text doesn't fight the UI */
  .pub-cover__tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--t1) 16%, transparent) 0%,
      transparent 50%,
      color-mix(in srgb, var(--t2) 12%, transparent) 100%
    );
    opacity: 0.65;
    pointer-events: none;
    z-index: 1;
  }

  /* Legibility scrim — dims baked-in Medium typography */
  .pub-cover__scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--media-ink) 30%, transparent) 0%,
      transparent 32%,
      color-mix(in srgb, var(--media-ink) 35%, transparent) 58%,
      color-mix(in srgb, var(--media-ink) 78%, transparent) 82%,
      color-mix(in srgb, var(--media-ink) 92%, transparent) 100%
    );
    pointer-events: none;
  }

  /* Animated theme layer — subtle accent only */
  .pub-cover__fx {
    position: absolute;
    inset: 0;
    opacity: 0.22;
    mix-blend-mode: soft-light;
    pointer-events: none;
    z-index: 3;
    mask-image: linear-gradient(to bottom, black 15%, transparent 88%);
    -webkit-mask-image: linear-gradient(to bottom, black 15%, transparent 88%);
  }
  .pub-cover__fx :global(.tv) {
    border-radius: 0;
  }

  .pub-cover__grain {
    position: absolute;
    inset: 0;
    z-index: 4;
    opacity: 0.1;
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.07) 1px,
      transparent 1px
    );
    background-size: 3px 3px;
    pointer-events: none;
    mix-blend-mode: overlay;
  }

  .pub-cover__vignette {
    position: absolute;
    inset: 0;
    z-index: 5;
    background: radial-gradient(
      ellipse at center,
      transparent 35%,
      color-mix(in srgb, var(--media-ink) 62%, transparent)
    );
    pointer-events: none;
  }

  .pub-cover--hero .pub-cover__img {
    transform: scale(1.05);
    filter: saturate(0.75) brightness(0.8) contrast(1.06) blur(1.5px);
    animation: cover-drift 18s var(--ease-in-out) infinite alternate;
  }
  .pub-cover--hero .pub-cover__scrim {
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--media-ink) 42%, transparent) 0%,
      transparent 22%,
      color-mix(in srgb, var(--media-ink) 48%, transparent) 52%,
      color-mix(in srgb, var(--media-ink) 88%, transparent) 78%,
      color-mix(in srgb, var(--media-ink) 96%, transparent) 100%
    );
  }
  .pub-cover--hero .pub-cover__fx {
    opacity: 0.18;
    mask-image: linear-gradient(to bottom, black 8%, transparent 80%);
    -webkit-mask-image: linear-gradient(to bottom, black 8%, transparent 80%);
  }

  .pub-cover--plain {
    background: var(--surface);
  }
  .pub-cover--plain .pub-cover__img {
    transform: scale(1.02);
    filter: none;
    transition: transform 1.1s var(--ease-out);
    will-change: transform;
  }

  @keyframes cover-drift {
    from {
      transform: scale(1.05) translate3d(0, 0, 0);
    }
    to {
      transform: scale(1.1) translate3d(-1.2%, -0.8%, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pub-cover__img,
    .pub-cover--hero .pub-cover__img {
      animation: none !important;
      transform: scale(1.02);
      filter: saturate(0.82) brightness(0.86) contrast(1.04);
    }
    .pub-cover--hero .pub-cover__img {
      filter: saturate(0.75) brightness(0.8) contrast(1.06);
    }
    :global(.article-card:hover) .pub-cover--card .pub-cover__img,
    :global(.article-card:focus-visible) .pub-cover--card .pub-cover__img,
    :global(.article-card:hover) .pub-cover--plain .pub-cover__img,
    :global(.article-card:focus-visible) .pub-cover--plain .pub-cover__img {
      transform: scale(1.02);
    }
  }
</style>
