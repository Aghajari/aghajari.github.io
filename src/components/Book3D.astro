---
/**
 * Book3D — a realistic hardcover rendered with CSS 3D transforms.
 * Front cover (official artwork) + spine + fore-edge pages + thickness,
 * with soft contact shadow and a light sheen. Resting pose shows the spine;
 * cursor tilt is wired up in `scripts/reading.ts`.
 */
interface Props {
  cover: string;
  title: string;
  author?: string;
  spine?: string;
  accent?: string;
  variant?: "shelf" | "hero";
  /** Optional shared-element name for cross-page morph. */
  transitionName?: string;
  eager?: boolean;
}
const {
  cover,
  title,
  author,
  spine = "#1b1b1f",
  accent = "#000000",
  variant = "shelf",
  transitionName,
  eager = false,
} = Astro.props;

// Choose legible spine lettering based on the binding's luminance, so light
// covers get dark ink and dark covers get light ink.
const hex = spine.replace("#", "");
const sr = parseInt(hex.slice(0, 2) || "1b", 16);
const sg = parseInt(hex.slice(2, 4) || "1b", 16);
const sb = parseInt(hex.slice(4, 6) || "1f", 16);
const lum = (0.2126 * sr + 0.7152 * sg + 0.0722 * sb) / 255;
const isLight = lum > 0.58;
const ink = isLight ? "rgba(26,22,18,0.92)" : "rgba(255,255,255,0.92)";
const inkSoft = isLight ? "rgba(26,22,18,0.6)" : "rgba(255,255,255,0.62)";
const inkShadow = isLight ? "0 1px 1px rgba(255,255,255,0.4)" : "0 1px 2px rgba(0,0,0,0.6)";
---

<div
  class:list={["book3d", `book3d--${variant}`]}
  data-book3d
  style={`--spine:${spine};--accent:${accent};--spine-ink:${ink};--spine-ink-soft:${inkSoft};--spine-ink-shadow:${inkShadow};`}
>
  <div class="book3d__stage">
    <div class="book3d__inner">
      <div class="book3d__face book3d__cover">
        <div class="book3d__fallback" aria-hidden="true">
          <span class="book3d__fallback-title">{title}</span>
          {author && <span class="book3d__fallback-author">{author}</span>}
        </div>
        {transitionName ? (
          <img
            class="book3d__img"
            src={cover}
            alt={`${title} — cover`}
            loading={eager ? "eager" : "lazy"}
            decoding="async"
            onerror="this.style.display='none'"
            transition:name={transitionName}
          />
        ) : (
          <img
            class="book3d__img"
            src={cover}
            alt={`${title} — cover`}
            loading={eager ? "eager" : "lazy"}
            decoding="async"
            onerror="this.style.display='none'"
          />
        )}
        <span class="book3d__sheen" aria-hidden="true"></span>
        <span class="book3d__hinge" aria-hidden="true"></span>
      </div>
      <div class="book3d__face book3d__spine" aria-hidden="true">
        <div class="book3d__spine-label">
          <span class="book3d__spine-title">{title}</span>
        </div>
      </div>
      <div class="book3d__face book3d__pages" aria-hidden="true"></div>
      <div class="book3d__face book3d__back" aria-hidden="true"></div>
      <div class="book3d__face book3d__top" aria-hidden="true"></div>
      <div class="book3d__face book3d__bottom" aria-hidden="true"></div>
    </div>
  </div>
  <div class="book3d__shadow" aria-hidden="true"></div>
</div>

<style>
  .book3d {
    --bw: 160px;
    --bh: calc(var(--bw) * 1.52);
    --bd: 40px;
    --ry: 28deg;
    --rx: 6deg;
    --lift: 0px;
    position: relative;
    width: var(--bw);
    display: flex;
    flex-direction: column;
    align-items: center;
    perspective: 1700px;
  }
  .book3d--hero {
    --bw: clamp(190px, 42vw, 290px);
    --bd: 52px;
  }

  .book3d__stage {
    width: var(--bw);
    height: var(--bh);
    transform-style: preserve-3d;
    transform: translateY(var(--lift));
    transition: transform 0.6s var(--ease-out);
  }

  .book3d__inner {
    position: relative;
    width: var(--bw);
    height: var(--bh);
    transform-style: preserve-3d;
    transform: rotateX(var(--rx)) rotateY(var(--ry));
    transition: transform 0.7s var(--ease-out);
    will-change: transform;
  }

  .book3d__face {
    position: absolute;
    top: 0;
    left: 0;
    backface-visibility: hidden;
  }

  /* Front + back are the broad faces */
  .book3d__cover,
  .book3d__back {
    width: var(--bw);
    height: var(--bh);
    border-radius: 3px 7px 7px 3px; /* binding edge sharper on the left */
    overflow: hidden;
  }
  .book3d__cover {
    transform: translateZ(calc(var(--bd) / 2));
    background: var(--spine);
    box-shadow:
      inset 0 0 0 1px rgba(0, 0, 0, 0.18),
      inset 6px 0 12px -6px rgba(0, 0, 0, 0.5); /* gutter shadow near spine */
  }
  .book3d__back {
    transform: rotateY(180deg) translateZ(calc(var(--bd) / 2));
    background:
      linear-gradient(120deg, color-mix(in srgb, var(--spine) 88%, #000), var(--spine));
    border-radius: 7px 3px 3px 7px;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.25);
  }

  .book3d__img {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Designed fallback if the cover artwork ever fails to load. */
  .book3d__fallback {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6em;
    padding: 12% 14%;
    text-align: center;
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(255, 255, 255, 0.12), transparent 60%),
      linear-gradient(160deg, color-mix(in srgb, var(--spine) 80%, #fff 6%), color-mix(in srgb, var(--spine) 92%, #000));
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .book3d__fallback-title {
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(0.95rem, 2.4vw, 1.35rem);
    line-height: 1.2;
    color: var(--spine-ink, rgba(255, 255, 255, 0.94));
    text-shadow: var(--spine-ink-shadow, 0 1px 3px rgba(0, 0, 0, 0.5));
  }
  .book3d__fallback-author {
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--spine-ink-soft, rgba(255, 255, 255, 0.6));
  }

  /* lighting sheen sweeping across the cover */
  .book3d__sheen {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        105deg,
        rgba(255, 255, 255, 0.32) 0%,
        rgba(255, 255, 255, 0.06) 18%,
        transparent 40%,
        transparent 78%,
        rgba(0, 0, 0, 0.22) 100%
      );
    mix-blend-mode: soft-light;
    pointer-events: none;
  }
  /* subtle hinge line where cover meets the spine */
  .book3d__hinge {
    position: absolute;
    top: 0;
    left: 5px;
    width: 2px;
    height: 100%;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.32),
      rgba(255, 255, 255, 0.06)
    );
    pointer-events: none;
  }

  /* Spine (left side) — title + author run along the binding, letters upright */
  .book3d__spine {
    width: var(--bd);
    height: var(--bh);
    left: calc(var(--bw) / 2 - var(--bd) / 2);
    transform: rotateY(-90deg) translateZ(calc(var(--bw) / 2));
    border-radius: 3px;
    background:
      linear-gradient(
        to right,
        rgba(0, 0, 0, 0.5) 0%,
        rgba(0, 0, 0, 0.28) 14%,
        rgba(255, 255, 255, 0.04) 50%,
        rgba(255, 255, 255, 0.1) 86%,
        rgba(0, 0, 0, 0.55) 100%
      ),
      var(--spine);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  /* Rotate so horizontal lettering runs top-to-bottom along the spine edge */
  .book3d__spine-label {
    transform: rotate(90deg);
    display: flex;
    align-items: center;
    justify-content: center;
    width: calc(var(--bh) * 0.88);
    max-width: calc(var(--bh) * 0.88);
    padding-inline: 0.2rem;
  }
  .book3d__spine-title {
    display: block;
    width: 100%;
    text-align: center;
    line-height: 1.1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(0.52rem, 1.15vw, 0.72rem);
    letter-spacing: 0.02em;
    font-weight: 600;
    color: var(--spine-ink, rgba(255, 255, 255, 0.92));
    text-shadow: var(--spine-ink-shadow, 0 1px 2px rgba(0, 0, 0, 0.6));
  }

  /* Fore-edge (right side) — stacked pages */
  .book3d__pages {
    width: var(--bd);
    height: var(--bh);
    left: calc(var(--bw) / 2 - var(--bd) / 2);
    transform: rotateY(90deg) translateZ(calc(var(--bw) / 2));
    background:
      repeating-linear-gradient(
        to bottom,
        #f5f1e6 0px,
        #f5f1e6 1px,
        #d8d2c0 1.5px,
        #efe9da 3px
      );
    border-radius: 0 3px 3px 0;
    box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.2);
  }

  /* Top + bottom — page block */
  .book3d__top,
  .book3d__bottom {
    width: var(--bw);
    height: var(--bd);
    top: calc(var(--bh) / 2 - var(--bd) / 2);
    background:
      repeating-linear-gradient(
        to right,
        #f3efe3 0px,
        #f3efe3 1px,
        #ddd6c4 1.5px,
        #ece6d6 3px
      );
  }
  .book3d__top {
    transform: rotateX(90deg) translateZ(calc(var(--bh) / 2));
    border-radius: 3px 3px 0 0;
    box-shadow: inset 0 2px 6px rgba(0, 0, 0, 0.16);
  }
  .book3d__bottom {
    transform: rotateX(-90deg) translateZ(calc(var(--bh) / 2));
    border-radius: 0 0 3px 3px;
    box-shadow: inset 0 -2px 6px rgba(0, 0, 0, 0.16);
  }

  /* Contact shadow on the surface below */
  .book3d__shadow {
    position: absolute;
    z-index: -1;
    left: 50%;
    bottom: -6px;
    width: calc(var(--bw) * 1.05);
    height: 26px;
    transform: translateX(-50%) rotateX(72deg);
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--accent) 22%, rgba(0, 0, 0, 0.55)) 0%,
      rgba(0, 0, 0, 0.28) 38%,
      transparent 72%
    );
    filter: blur(7px);
    opacity: 0.7;
    transition: opacity 0.6s var(--ease-out), transform 0.6s var(--ease-out);
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .book3d__inner,
    .book3d__stage,
    .book3d__shadow {
      transition: none !important;
    }
  }
</style>
